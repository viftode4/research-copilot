# Research Copilot Configuration
# Copy to .env and fill in your values

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (default: claude-opus-4-6)
RC_MODEL=claude-opus-4-6
RC_MAX_BUDGET_USD=5.0
RC_MAX_TURNS=50

# PostgreSQL
RC_DB_HOST=localhost
RC_DB_PORT=5432
RC_DB_NAME=research_copilot
RC_DB_USER=research_copilot
RC_DB_PASSWORD=

# Weights & Biases
RC_WANDB_API_KEY=
RC_WANDB_ENTITY=
RC_WANDB_PROJECT=

# Slurm (leave empty for mock mode)
RC_SLURM_HOST=
RC_SLURM_USER=
RC_SLURM_SSH_KEY_PATH=
RC_SLURM_PARTITION=gpu
RC_SLURM_DEFAULT_GPUS=1
RC_SLURM_DEFAULT_TIME=04:00:00

# Literature APIs
RC_LIT_SEMANTIC_SCHOLAR_API_KEY=
RC_LIT_ARXIV_MAX_RESULTS=20
RC_LIT_SEMANTIC_SCHOLAR_MAX_RESULTS=20
